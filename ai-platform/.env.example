PROXY_HOST=your-proxy-host
PROXY_PORT=your-proxy-port
PROXY_USER=your-proxy-username
PROXY_PASS=your-proxy-password
VNC_PASSWORD=claude
# Host directory with your projects (mounted as /workspace)
PROJECTS_DIR=/absolute/path/to/your/projects
# Optional basic auth for the web UI (recommended if exposed beyond localhost).
# Leave UI_PASSWORD empty to disable.
UI_USER=admin
UI_PASSWORD=

# Google Gemini (AI Studio key from https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Model used to explain a diff selection ("Что делает" / "Как работает") and to
# review the uncommitted diff. Both run as `claude -p` inside the Claude
# container, so they need no API key.
EXPLAIN_MODEL=sonnet
EXPLAIN_TIMEOUT_MS=120000
REVIEW_MODEL=sonnet
REVIEW_TIMEOUT_MS=240000
