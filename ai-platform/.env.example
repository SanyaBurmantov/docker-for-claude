PROXY_HOST=your-proxy-host
PROXY_PORT=your-proxy-port
PROXY_USER=your-proxy-username
PROXY_PASS=your-proxy-password
VNC_PASSWORD=claude
# Host directory with your projects (mounted as /workspace)
PROJECTS_DIR=/absolute/path/to/your/projects

# The backend and the agent run as this uid/gid, so files they create in
# PROJECTS_DIR belong to you on the host and stay editable in your IDE.
#   HOST_UID=$(id -u)  HOST_GID=$(id -g)
# DOCKER_GID lets the backend reach /var/run/docker.sock without being root:
#   DOCKER_GID=$(getent group docker | cut -d: -f3)
# Changing HOST_UID/HOST_GID requires `docker compose build`, not just a restart.
HOST_UID=1000
HOST_GID=1000
DOCKER_GID=
# Optional basic auth for the web UI (recommended if exposed beyond localhost).
# Leave UI_PASSWORD empty to disable.
UI_USER=admin
UI_PASSWORD=

# Google Gemini (AI Studio key from https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# DashScope / Alibaba Qwen (https://dashscope.console.aliyun.com)
# Configured as a custom provider in claude-container/opencode.json for opencode.
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-max

# Model used to explain a diff selection ("Что делает" / "Как работает"), to
# review the uncommitted diff and to write a commit message for it. All three run
# as `claude -p` inside the Claude container, so they need no API key.
EXPLAIN_MODEL=sonnet
EXPLAIN_TIMEOUT_MS=120000
REVIEW_MODEL=sonnet
REVIEW_TIMEOUT_MS=240000
COMMIT_MESSAGE_MODEL=sonnet
COMMIT_MESSAGE_TIMEOUT_MS=90000
