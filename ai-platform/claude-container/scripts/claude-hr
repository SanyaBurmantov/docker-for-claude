#!/bin/bash

# Launch Claude Code through the Headroom compression proxy.
#
# Headroom sits between Claude Code and api.anthropic.com and shrinks tool output,
# logs and file contents before they reach the model, cutting the tokens spent per
# turn. Everything else is identical to running `claude` directly — this script
# forwards its arguments verbatim, so --resume / --session-id / a positional prompt
# all work exactly as the platform expects.
#
# One proxy serves every project in the container: the first `claude-hr` starts it,
# later ones find it already up and reuse it.
set -e

PORT=8787
BASE="http://127.0.0.1:${PORT}"

if ! curl -sf "${BASE}/livez" >/dev/null 2>&1; then
  nohup headroom proxy >/tmp/headroom-proxy.log 2>&1 &
  # The proxy loads its Rust core before it answers /readyz, so wait rather than
  # racing Claude Code's first request against a half-open port.
  for _ in $(seq 1 40); do
    curl -sf "${BASE}/readyz" >/dev/null 2>&1 && break
    sleep 0.5
  done
fi

# 127.0.0.1 is in NO_PROXY, so Claude Code -> Headroom stays local and skips the
# egress gateway. Headroom itself reaches api.anthropic.com through HTTPS_PROXY,
# the same route every other client in this container takes.
export ANTHROPIC_BASE_URL="${BASE}"
exec claude "$@"
