+              />
+              Кросс-критика Gemini
+            </label>
+          </div>
+        )}
+
+        <div className="promptgen-composer">
+          <textarea
+            className="promptgen-input"
+            value={rough}
+            onChange={(e) => setRough(e.target.value)}
+            placeholder="Опиши что надо промту делать…"
+            rows={4}
