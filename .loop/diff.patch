+        text,
+        settings,
+        {
+          onText: (chunk) => setResult((prev) => prev + chunk),
+          onNote: (note) => setNotes((prev) => [...prev, note]),
+          onReset: () => setResult(''),
+          onCost: (c) => setCost(c),
+        },
+        controller.signal
+      )
+    } catch (err) {
+      if (controller.signal.aborted) return
+      setError((err as Error).message)
+    } finally {
+      setStreaming(false)
